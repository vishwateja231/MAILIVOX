{
  "manifest_version": 3,
  "name": "Mailivox LinkedIn Extractor",
  "version": "1.0.0",
  "description": "Extract LinkedIn profiles and connection emails into Mailivox.",
  "permissions": [
    "activeTab",
    "storage",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://mailivox.vercel.app/*",
    "http://localhost:5173/*",
    "http://localhost:5174/*",
    "http://localhost:3000/*",
    "https://mailivox-backend.onrender.com/*"
  ],
  "action": {
    "default_title": "Mailivox",
    "default_popup": "popup/popup.html"
  },
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/*"],
      "js": ["content/scraper.js", "content/connections.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://mailivox.vercel.app/*", "http://localhost:5173/*", "http://localhost:5174/*"],
      "js": ["content/auth-capture.js"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "options/options.html"
}
